NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://ledgerflow:ledgerflow@localhost:5432/ledgerflow?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Credential encryption (32-byte hex for AES-256-GCM). Generate: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS
CORS_ORIGIN=http://localhost:5173

# Public frontend base URL — used to build invitation / password-reset links.
APP_BASE_URL=http://localhost:5173

# 2FA issuer label shown in authenticator apps.
TOTP_ISSUER=LedgerFlow

# Outbound email (SMTP). Leave SMTP_HOST empty to run in dev mode: links are
# logged + returned in the API response instead of being emailed.
EMAIL_FROM=LedgerFlow <no-reply@ledgerflow.local>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Connector mode: "mock" or "yuki"
CONNECTOR_MODE=mock

# Stripe (use TEST keys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_STARTER=price_starter_placeholder
STRIPE_PRICE_PROFESSIONAL=price_professional_placeholder
STRIPE_PRICE_OFFICE=price_office_placeholder
STRIPE_SUCCESS_URL=http://localhost:5173/billing/success
STRIPE_CANCEL_URL=http://localhost:5173/billing/cancel

# Logging
LOG_LEVEL=info
