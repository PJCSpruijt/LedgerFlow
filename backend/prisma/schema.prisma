// LedgerFlow Prisma schema
// Multi-tenant SaaS hierarchy: Workspace > Group > Entity.
// Users get access via Membership rows scoped to exactly one of those levels.
// Subscriptions live at the Workspace; connectors at the Entity; audit logs at the Workspace.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Platform-wide role, distinct from the per-scope membership roles. PLATFORM_ADMIN
// is the superuser: bypasses subscription limits and has access to every
// workspace/group/entity and all admin/test functionality.
enum PlatformRole {
  PLATFORM_ADMIN
  USER
}

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String
  firstName     String
  lastName      String
  platformRole  PlatformRole @default(USER)
  // Login stats (set on each successful authentication, incl. completed 2FA).
  lastLoginAt   DateTime?
  loginCount    Int          @default(0)
  // 2FA (TOTP). The secret is AES-256-GCM encrypted at rest (utils/crypto).
  // `enabled` = enrollment confirmed (challenged at login); `required` = an
  // admin mandated 2FA for this user (must enroll).
  twoFactorEnabled  Boolean @default(false)
  twoFactorRequired Boolean @default(false)
  twoFactorSecret   String?
  // Optional profile picture, stored as a small data: URL (client-resized).
  avatarUrl     String?
  // Per-user dashboard widget preferences: list of DISABLED widget keys
  // (so newly added widgets are visible by default). e.g. ["unmappedVat"].
  dashboardWidgets Json?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  userTokens    UserToken[]

  @@index([email])
}

// Single-use tokens for admin-initiated invitations and password resets. Only a
// SHA-256 hash of the raw token is stored; the raw value lives only in the email
// link. Consumed exactly once (usedAt) before its expiry.
enum UserTokenKind {
  INVITE
  PASSWORD_RESET
}

model UserToken {
  id        String        @id @default(uuid())
  userId    String
  kind      UserTokenKind
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A Workspace is the commercial tenant (billing lives here). COMPANY = a single
// business managing its own books; ACCOUNTING_FIRM = a firm managing many clients.
enum WorkspaceType {
  COMPANY
  ACCOUNTING_FIRM
}

model Workspace {
  id        String        @id @default(uuid())
  name      String
  type      WorkspaceType @default(COMPANY)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  groups       Group[]
  memberships  Membership[]
  subscription Subscription?
  auditLogs    AuditLog[]
  vatMappings  VatMapping[]
  finCategories     FinSemanticCategory[]
  rgsMappings       SourceAccountMapping[]
  accountDefaults   WorkspaceAccountDefault[]
  settings          WorkspaceSettings?
  apiKeys           ApiKey[]
}

// A Group is a consolidation group inside a workspace (e.g. a holding).
model Group {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entities    Entity[]
  memberships Membership[]
  auditLogs   AuditLog[]

  @@index([workspaceId])
}

// An Entity is a single administration / legal entity. Connectors attach here.
model Entity {
  id        String   @id @default(uuid())
  groupId   String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group          Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  connection     Connection?
  memberships    Membership[]
  auditLogs      AuditLog[]
  vatMappings    VatMapping[]
  sourceAccounts SourceAccount[]
  rgsMappings    SourceAccountMapping[]

  @@index([groupId])
}

// The scope level a Membership is attached to. Exactly one of the matching FK
// columns is set (enforced by a CHECK constraint defined in raw SQL).
enum ScopeLevel {
  WORKSPACE
  GROUP
  ENTITY
}

// Per-scope roles (replaces the old flat OrganizationRole). PLATFORM_ADMIN stays
// platform-wide on User and bypasses all of these.
enum ScopedRole {
  WORKSPACE_ADMIN
  ACCOUNTANT_ADMIN
  ACCOUNTANT_USER
  CLIENT_ADMIN
  CLIENT_USER
  READ_ONLY
  MAPPING_MANAGER
  CONSOLIDATION_MANAGER
}

// Polymorphic membership: one row grants a user a role at exactly one scope.
// Effective access to an entity = a membership on that entity, its parent group,
// or the workspace. Partial unique indexes + a CHECK constraint live in raw SQL.
model Membership {
  id          String     @id @default(uuid())
  userId      String
  scopeLevel  ScopeLevel
  role        ScopedRole
  workspaceId String?
  groupId     String?
  entityId    String?
  createdAt   DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  group     Group?     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entity    Entity?    @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([groupId])
  @@index([entityId])
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  OFFICE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAUSED
  NONE
}

enum BillingInterval {
  MONTH
  YEAR
}

// The plan catalog, managed by platform admins. Pricing and the set of feature
// modules a plan grants live here (the module KEYS are code-defined in
// src/config/modules.ts). `key` is a stable machine identifier; for the three
// seeded plans it matches the legacy SubscriptionPlan enum so Stripe price
// mapping keeps working.
model Plan {
  id            String          @id @default(uuid())
  key           String          @unique
  name          String
  description   String?
  priceCents    Int             @default(0)
  currency      String          @default("EUR")
  interval      BillingInterval @default(MONTH)
  modules       String[]        @default([])
  stripePriceId String?
  active        Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                    String             @id @default(uuid())
  workspaceId           String             @unique
  stripeCustomerId      String?
  stripeSubscriptionId  String?            @unique
  // Legacy enum kept for backward compat with the Stripe price mapping; `planId`
  // is the authoritative link to the managed plan catalog. A manual (non-Stripe)
  // assignment sets planId directly.
  plan                  SubscriptionPlan?
  planId                String?
  status                SubscriptionStatus @default(NONE)
  validUntil            DateTime?
  // True when the customer has cancelled but the paid period is still running:
  // access continues until validUntil, then Stripe stops the incasso.
  cancelAtPeriodEnd     Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planRef   Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([stripeCustomerId])
  @@index([planId])
}

enum YukiEnvironment {
  PRODUCTION
  SANDBOX
}

// Which accounting system a connection talks to. The generic connector layer
// dispatches on this (see clients/connectors/registry.ts).
enum ConnectionKind {
  YUKI
  EBOEKHOUDEN
}

// A connector binding for an entity (one administration). Credentials are
// AES-256-GCM encrypted at rest and NEVER returned to the frontend. The shape of
// the decrypted payload depends on `kind`:
//   YUKI        → { accessKey, administrationId }
//   EBOEKHOUDEN → { accessToken, source? }
model Connection {
  id                   String          @id @default(uuid())
  entityId             String          @unique
  kind                 ConnectionKind  @default(YUKI)
  encryptedCredentials String
  // Yuki-only: production vs sandbox. Ignored by other connectors.
  environment          YukiEnvironment @default(PRODUCTION)
  lastTestedAt         DateTime?
  lastSyncAt           DateTime?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

// User-maintained VAT account mappings, scoped to a workspace and optionally a
// single entity (entity-specific wins over workspace-wide). The connector
// resolution layer applies these to generated VAT lines; connector inference
// NEVER overwrites a mapping a user has set.
model VatMapping {
  id                      String   @id @default(uuid())
  workspaceId             String
  entityId                String?
  sourceVatCode           String
  // Optional finer key: the source revenue/cost ledger code the VAT relates to.
  // "" = applies to any source ledger for this VAT code.
  sourceLedgerAccountCode String   @default("")
  // The GL account VAT should post to (a ledger code today; the universal tax
  // account once the universal chart of accounts (phase 4) exists).
  targetLedgerCode        String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity    Entity?   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([entityId])
}

model AuditLog {
  id          String   @id @default(uuid())
  workspaceId String
  groupId     String?
  entityId    String?
  userId      String?
  action      String
  metadata    Json?
  timestamp   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  group     Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  entity    Entity?   @relation(fields: [entityId], references: [id], onDelete: SetNull)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, timestamp])
  @@index([action])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// API key for the external FIN//HUB Output API (#30). Read-only by default and
// scoped to a workspace (optionally narrowed to one entity). Only a SHA-256 hash
// of the key is stored; the raw value is shown once at creation.
model ApiKey {
  id              String    @id @default(uuid())
  workspaceId     String
  name            String
  prefix          String // first chars of the key, for display (e.g. "fhk_ab12cd")
  keyHash         String    @unique // sha256(full key)
  scopes          String[]  @default(["read"])
  entityId        String? // optional narrowing to one administration
  rateLimitPerMin Int       @default(120)
  createdByUserId String?
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([keyHash])
}

// Append-only ledger of EVERY outbound connector request (#26). Used for vendor
// cost control, customer usage reporting, rate-limit management and (later) the
// Output API's audit/lineage. SECURITY: never store API keys/tokens or full
// sensitive payloads here — only hashes + sizes + metadata.
model ApiUsageLog {
  id                     String    @id @default(uuid())
  requestId              String // unique per outbound HTTP/SOAP call
  correlationId          String? // groups all calls within one inbound request
  jobId                  String?
  startedAt              DateTime
  endedAt                DateTime
  durationMs             Int
  workspaceId            String?
  groupId                String?
  entityId               String?
  connectorType          String? // YUKI | EBOEKHOUDEN | MOCK
  connectorAccountId     String? // Connection.id
  sourceAdministrationId String?
  // Channel dimension — distinguishes interactive user traffic from machine/API
  // traffic, and the direction of the call. "Gebruiker bevraagt boekhoudpakket"
  // = OUTBOUND + USER; "externe software bevraagt FIN//HUB" = INBOUND + API.
  initiatorType          String    @default("USER") // USER | API | SYSTEM
  direction              String    @default("OUTBOUND") // OUTBOUND (FIN//HUB→bron) | INBOUND (extern→FIN//HUB)
  // External API client id when initiatorType = API (filled by the Output API, #30).
  apiClientId            String?
  operationType          String // auth | token_refresh | coa_sync | transactions_sync | …
  endpointName           String // path or service.method
  httpMethod             String?
  soapAction             String?
  statusCode             Int?
  success                Boolean
  errorCode              String?
  errorMessage           String?
  retryCount             Int       @default(0)
  recordsRequested       Int?
  recordsReceived        Int?
  bytesSent              Int?
  bytesReceived          Int?
  paginationCursor       String?
  rateLimitLimit         Int?
  rateLimitRemaining     Int?
  rateLimitResetAt       DateTime?
  initiatedBy            String? // user id (null for system/cron)
  requestHash            String? // sha256 of redacted request descriptor
  responseHash           String? // sha256 of response body
  createdAt              DateTime  @default(now())

  @@index([workspaceId, startedAt])
  @@index([entityId, startedAt])
  @@index([connectorType, startedAt])
  @@index([success, startedAt])
  @@index([initiatorType, startedAt])
}

// Cached daily FX rates (ECB via Frankfurter). Keyed by the REQUESTED date plus
// the from/to currencies; rateDate is the actual ECB business day used (may drift
// on weekends/holidays). Lets reporting convert to one currency cheaply.
model FxRate {
  date      String // requested date, YYYY-MM-DD
  base      String // from currency (ISO-4217)
  quote     String // to currency
  rate      Float
  rateDate  String // actual ECB date returned
  fetchedAt DateTime @default(now())

  @@id([date, base, quote])
  @@index([base, quote])
}

// Records every Stripe event id we've already handled, so duplicate webhook
// deliveries (Stripe retries / at-least-once delivery) become no-ops.
model ProcessedStripeEvent {
  eventId     String   @id
  type        String
  processedAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// RGS (Referentie Grootboekschema) normalization layer.
//   Source Account → RGS Mapping → FIN semantic layer → Reporting / Consolidation
// ---------------------------------------------------------------------------

// The canonical RGS taxonomy. RGS is a public, versioned Dutch standard, so this
// is PLATFORM-GLOBAL (not per tenant): imported once per version by a platform
// admin and referenced by everyone via (version, code). ~1500 (MKB) – 4900
// (decimaal) rows per version.
model RgsAccount {
  id               String   @id @default(uuid())
  version          String // "3.5"
  code             String // referentiecode, e.g. "BIvaKou"
  referentienummer String? // 9-digit referentiegrootboeknummer
  description      String // grootboekomschrijving
  category         String? // rubriek / hoofdrubriek label
  // Referentiecode of the parent level (hierarchy is encoded in the code itself).
  parentCode       String?
  level            Int // 1..5 (verantwoording → hoofdrubriek → rubriek → rekening → mutatie)
  rgsType          String // "report" | "mainGroup" | "category" | "account" | "mutation"
  dc               String? // "D" | "C"
  isBalanceSheet   Boolean  @default(false) // code starts with B
  isProfitLoss     Boolean  @default(false) // code starts with W
  omslagCode       String? // alternative code used on the opposite balance sign
  sbrConcept       String? // hook for SBR / auditfile interop (later phase)
  applicability    Json? // entity-type flags (ZZP / EZ / BV / …) from the dataset
  createdAt        DateTime @default(now())

  @@unique([version, code])
  @@index([version, parentCode])
  @@index([version, level])
}

// GL accounts discovered from a connector's trial balance — the raw "universal
// chart of accounts" layer, per entity. Immutable source data; mappings live
// separately so the raw layer is never rewritten.
model SourceAccount {
  id          String   @id @default(uuid())
  entityId    String
  code        String
  name        String
  accountType String   @default("UNKNOWN") // "BALANCE" | "PROFIT_LOSS" | "UNKNOWN"
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, code])
  @@index([entityId])
}

// FIN//HUB semantic categories, deliberately SEPARATE from RGS (RGS does not
// model MRR/ARR/EBITDA/…). workspaceId null = platform default available to all
// workspaces; a workspace may add its own on top.
model FinSemanticCategory {
  id          String   @id @default(uuid())
  workspaceId String?
  key         String // "MRR", "ARR", "EBITDA", …
  label       String
  kind        String   @default("METRIC") // "REVENUE" | "COST" | "METRIC"
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  SourceAccountMapping[]
  accountDefaults WorkspaceAccountDefault[]

  @@unique([workspaceId, key])
  @@index([workspaceId])
}

// Source account → RGS code (+ optional FIN category). IMMUTABLE and AUDITABLE:
// a change never UPDATEs/DELETEs a row — it inserts a new one and stamps
// `supersededAt` on the prior current row. The active mapping for a source
// account is the row with supersededAt = null. Entity-specific resolution
// mirrors VatMapping (an entity mapping wins; workspace-wide fallback via
// entityId-null rows is reserved for a later phase).
model SourceAccountMapping {
  id                String    @id @default(uuid())
  workspaceId       String
  entityId          String
  sourceAccountCode String
  rgsVersion        String    @default("3.5")
  rgsCode           String?
  finCategoryId     String?
  confidence        String    @default("MANUAL") // "EXACT" | "SUGGESTED" | "MANUAL"
  createdByUserId   String?
  createdAt         DateTime  @default(now())
  supersededAt      DateTime? // null = active; set when replaced by a newer mapping

  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity      Entity               @relation(fields: [entityId], references: [id], onDelete: Cascade)
  finCategory FinSemanticCategory? @relation(fields: [finCategoryId], references: [id], onDelete: SetNull)

  @@index([workspaceId, entityId, sourceAccountCode, supersededAt])
  @@index([entityId, supersededAt])
}

// Workspace-wide RGS default mapping per source-account code. An administration
// inherits the default for a code UNLESS it has its own (entity-specific)
// SourceAccountMapping, which always wins. Lets one mapping set be reused across
// all administrations and seeded via import. Mutable (upsert), one row per code.
model WorkspaceAccountDefault {
  id                String   @id @default(uuid())
  workspaceId       String
  sourceAccountCode String
  rgsVersion        String   @default("3.5")
  rgsCode           String?
  finCategoryId     String?
  createdByUserId   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  finCategory FinSemanticCategory? @relation(fields: [finCategoryId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, sourceAccountCode])
  @@index([workspaceId])
}

// Canonical relation override. The same external party (debtor/creditor) often
// appears in multiple administrations under slightly different names. By default
// relations are grouped automatically by normalized name; this row is the manual
// override that pins a per-administration relation to a chosen canonical group
// (canonicalKey) — letting the user merge differently-named relations or split a
// wrongly-merged one, and attach canonical attributes (display name, VAT, email).
model RelationCanonicalOverride {
  id              String   @id @default(uuid())
  workspaceId     String
  entityId        String // administration where the relation lives
  relationId      String // connector relation id
  relationName    String?
  canonicalKey    String // the canonical group this relation belongs to
  displayName     String?
  vatNumber       String?
  email           String?
  note            String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityId, relationId])
  @@index([workspaceId])
  @@index([workspaceId, canonicalKey])
}

// Per-workspace feature/normalization settings (1:1 with Workspace).
model WorkspaceSettings {
  id          String   @id @default(uuid())
  workspaceId String   @unique
  rgsEnabled  Boolean  @default(false)
  rgsRequired Boolean  @default(false) // required → unmapped accounts are flagged/blocked
  rgsVersion  String   @default("3.5")
  extra       Json? // future toggles (notifications, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// Intercompany relation map: marks which connector relations (debtor/creditor)
// inside an administration are actually ANOTHER administration in the workspace,
// so their mutual balances can be eliminated on consolidation. Stored with plain
// id fields (validated in the service) to avoid extra back-relations on Entity.
model IntercompanyRelation {
  id                   String   @id @default(uuid())
  workspaceId          String
  entityId             String // administration where the relation lives
  relationId           String // connector relation id (ContactSummary.id)
  relationCode         String?
  relationName         String?
  counterpartyEntityId String // which workspace entity this relation IS
  createdByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([entityId, relationId])
  @@index([workspaceId])
  @@index([counterpartyEntityId])
}

// Per-account elimination override (capital/RC/loan consolidation). Controls
// whether a specific GL account in an administration is eliminated on
// consolidation and against WHICH workspace administration. Auto-detection
// suggests a default from the account name (a participation/RC naming an
// in-scope administration eliminates against it; one naming a company OUTSIDE
// the consolidation must NOT be eliminated). This row is the manual override
// that wins over auto-detection. Keyed per (entity, glAccountCode).
model EliminationAccountMapping {
  id                   String   @id @default(uuid())
  workspaceId          String
  entityId             String // administration where the GL account lives
  glAccountCode        String // the grootboekrekening
  glAccountName        String?
  eliminate            Boolean  @default(true) // false = never eliminate this account
  counterpartyEntityId String? // which workspace administration is the counterparty
  category             String? // optional category override (EQUITY_INVESTMENT/CURRENT_ACCOUNT/LOAN/…)
  note                 String?
  createdByUserId      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([entityId, glAccountCode])
  @@index([workspaceId])
  @@index([counterpartyEntityId])
}

// A frozen, point-in-time consolidation result. Stores the full computed
// snapshot (leaves, eliminations, imbalances, entities) so a consolidated
// reporting position is reproducible even when the live connector data changes.
model ConsolidationRun {
  id              String   @id @default(uuid())
  workspaceId     String
  groupId         String?
  label           String
  scope           String // "group" | "workspace"
  fromDate        String
  toDate          String
  currency        String
  eliminate       Boolean  @default(false)
  entityCount     Int      @default(0)
  snapshot        Json
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([groupId])
}

// Day-cache of connector data (trial balance, transactions, debtors/creditors,
// outstanding) per administration + params, so repeated views (dashboard,
// grootboek, transacties, consolidatie) don't re-hit the accounting API every
// time. The payload is AES-256-GCM encrypted at rest (financial data → AVG);
// entries carry a fetchedAt for a TTL and "laatst opgehaald"-display, and can be
// force-refreshed by the user.
model ConnectorCache {
  id        String   @id @default(uuid())
  entityId  String
  method    String // "trialBalance" | "transactions" | "debtors" | "creditors" | "outstanding"
  paramsKey String // e.g. "2025-01-01|2025-12-31" or "debtor"
  payload   String // AES-256-GCM encrypted JSON of the raw connector result
  rowCount  Int      @default(0)
  fetchedAt DateTime @default(now())

  @@unique([entityId, method, paramsKey])
  @@index([entityId])
  @@index([fetchedAt])
}

// Manual consolidation correction (double-entry): a journal the auto-elimination
// can't infer — intercompany profit in inventory, reclassifications, roundings.
// Applied on top of the consolidated figures for periods covering effectiveDate.
model ConsolidationAdjustment {
  id              String   @id @default(uuid())
  workspaceId     String
  groupId         String? // null = applies to the whole-workspace consolidation
  description     String
  debitRgsCode    String
  creditRgsCode   String
  amount          Float
  currency        String   @default("EUR")
  effectiveDate   String // YYYY-MM-DD
  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([workspaceId])
  @@index([groupId])
}
